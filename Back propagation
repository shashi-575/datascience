import numpy as np
X = np.array([[0,0],[0,1],[1,0],[1,1]])
y = np.array([[0],[1],[1],[0]])
np.random.seed(1)
weights = np.random.rand(2,1)
def sigmoid(x):
return 1/(1+np.exp(-x))
def sigmoid_derivative(x):                                                                                                
return x*(1-x) 
for i in range(10000):
output = sigmoid(np.dot(X, weights))
error = y - output
weights += np.dot(X.T, error * sigmoid_derivative(output))
print("Output:\n", output)
